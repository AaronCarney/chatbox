# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/chatbridge

# Redis
REDIS_URL=redis://localhost:6379

# Firebase Auth (server)
FIREBASE_SERVICE_ACCOUNT_B64=your-base64-encoded-service-account-json

# Firebase Auth (client — safe to commit, public by design)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Spotify OAuth
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:3001/api/oauth/spotify/callback

# Server
PORT=3001
VITE_API_URL=http://localhost:3001
